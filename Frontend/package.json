    "dompurify": "^3.3.0",
    "framer-motion": "^12.23.24",
    "i18next": "^25.6.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.554.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^16.3.3",
